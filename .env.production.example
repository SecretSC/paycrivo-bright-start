# ---- PayCrivo Frontend (production) ----
# Copy to .env.production (or .env) and adjust for your domain.
# This file is safe to commit as an EXAMPLE only; never commit real .env files.

# Public base URL of the PayCrivo API (the Express server in /server).
VITE_API_BASE_URL=https://api.paycrivo.com

# Leave unset in production. Only set to "true" on a private build if you need
# to surface email verification codes in the UI for internal checks.
# VITE_SHOW_DEV_CODES=false
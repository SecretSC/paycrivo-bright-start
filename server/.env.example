# ---- PayCrivo Backend Environment ----
# Copy to .env and fill in real values. NEVER commit .env.

# Server
PORT=4100
NODE_ENV=development
# Comma-separated list of allowed frontend origins for CORS
CORS_ORIGINS=http://localhost:8080,http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://paycrivo:paycrivo@localhost:5432/paycrivo?schema=public

# Auth secrets (use long random strings; keep customer + admin separate)
JWT_CUSTOMER_SECRET=change-me-customer-secret
JWT_ADMIN_SECRET=change-me-admin-secret
JWT_CUSTOMER_TTL=7d
JWT_ADMIN_TTL=12h

# First admin (seeded via `npm run seed:admin`). Never shipped to frontend.
ADMIN_EMAIL=admin@paycrivo.com
ADMIN_PASSWORD=ChangeThisStrongPassword123!
ADMIN_NAME=PayCrivo Admin

# SMTP (transactional OTP + support email). Password never exposed in any API.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=no-reply@paycrivo.com
SMTP_FROM_NAME=PayCrivo

# OTP policy
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
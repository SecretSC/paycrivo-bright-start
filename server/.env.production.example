# ---- PayCrivo Backend (production) ----
# Copy to .env on the server and fill in real values. NEVER commit .env.

# Server
PORT=4100
NODE_ENV=production
# Comma-separated list of allowed frontend origins (your real domains).
CORS_ORIGINS=https://paycrivo.com,https://www.paycrivo.com

# Database (PostgreSQL)
DATABASE_URL=postgresql://paycrivo:STRONG_DB_PASSWORD@localhost:5432/paycrivo?schema=public

# Auth secrets — generate with: openssl rand -hex 48
JWT_SECRET=replace-with-long-random-string
JWT_CUSTOMER_SECRET=replace-with-long-random-string
JWT_ADMIN_SECRET=replace-with-different-long-random-string
JWT_CUSTOMER_TTL=7d
JWT_ADMIN_TTL=12h

# First admin account (seeded via `npm run seed:admin`). Never shipped to frontend.
ADMIN_EMAIL=admin@paycrivo.com
ADMIN_PASSWORD=ChangeThisStrongPassword123!
ADMIN_NAME=PayCrivo Admin

# SMTP (transactional OTP + support email). Password is never exposed by any API.
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM_EMAIL=no-reply@paycrivo.com
SMTP_FROM_NAME=PayCrivo

# OTP policy
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60